# LifeTrace: local env with actual cpolar domain / secrets
.env
.dev.env

# LifeTrace: Firebase config files (only needed to make build pass)
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist

# Kotlin compiler cache
/android/.kotlin/

# Generated .g.dart files (build_runner output)
